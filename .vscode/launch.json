{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Watch)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: watch",          // ← запускает watch перед дебагом
      "env": {
        "VSCODE_DEBUGGER": "1"                // опционально, для доп. логов
      }
    }
  ]
}